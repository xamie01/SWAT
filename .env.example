# ══════════════════════════════════════════════════════════════════════════════
# SWAT Intelligence Platform — Environment Configuration
# Copy this file to .env and fill in the values before running any service.
# ══════════════════════════════════════════════════════════════════════════════

# ── Infrastructure ────────────────────────────────────────────────────────────
# Required by: ALL services (packages/db/src/client.ts)
DATABASE_URL=postgresql://swat:swat@localhost:5432/swat

# Required by: api, indexer, signal-engine, alert-service, trade-executor
REDIS_URL=redis://localhost:6379

# ── Ports ─────────────────────────────────────────────────────────────────────
# Used by: apps/api (default: 3001)
PORT=3001

# Used by: apps/indexer webhook server (default: 3002)
WEBHOOK_PORT=3002

# Used by: apps/web (Next.js frontend)
# API base URL for server-side fetches. Falls back to http://localhost:3001.
# In production, set to your public API URL (e.g., https://api.yoursite.com)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Security ──────────────────────────────────────────────────────────────────
# ⚠️ CHANGE THIS before going live.
# Used by: apps/api — all routes require X-Api-Key: <this value>
API_KEY=swat-dev-key

# ── Helius (Solana RPC + Webhooks) ────────────────────────────────────────────
# ✅ REQUIRED for the system to function.
# Used by: apps/indexer (backfill), apps/signal-engine (live safety checks)
# Get your key at: https://helius.dev → Dashboard → API Keys
HELIUS_API_KEY=

# Optional — only required if you register a real-time webhook in Helius.
# Used by: apps/indexer/src/webhook.ts for HMAC signature verification.
# Must match the "Webhook Secret" you set in the Helius dashboard.
# Leave empty to skip verification (development only).
HELIUS_WEBHOOK_SECRET=

# ── Telegram Alerts ───────────────────────────────────────────────────────────
# ✅ REQUIRED to receive trade alerts.
# Get token from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# Your Telegram chat or group ID.
# Find it: message @userinfobot, or add @RawDataBot to your group.
TELEGRAM_CHAT_ID=

# ── Execution Bot ─────────────────────────────────────────────────────────────
# Only required when TRADING_MODE=live AND AUTO_EXECUTE=true.
# Trojan is the recommended execution bot.
# Leave empty to run in paper-only mode indefinitely.
TROJAN_WEBHOOK_URL=
TROJAN_API_KEY=

# ── Trading Configuration ─────────────────────────────────────────────────────
# Used by: apps/trade-executor, apps/api (/v1/trading/status)

# 'paper' = log trades only (safe, default)
# 'live'  = execute real trades via TROJAN_WEBHOOK_URL
TRADING_MODE=paper

# Master switch for automatic trade execution.
# ⚠️ Keep false until signal quality is validated over 2+ weeks.
# Used by: apps/trade-executor
AUTO_EXECUTE=false

# Minimum signal score (0–100) to trigger an automatic trade.
# Manual execution via /v1/signals/:id/execute ignores this threshold.
# Used by: apps/trade-executor
AUTO_EXECUTE_MIN_SCORE=90

# Base trade size in SOL before tier × score multipliers are applied.
# Final size = BASE_POSITION_SOL × tier_multiplier × score_multiplier
#   elite×score≥90  → 1.0 × 1.0 × base = full base
#   promising×score≥80 → 0.5 × 0.75 × base = 37.5% of base
# Used by: apps/trade-executor, apps/alert-service (suggested execution display)
BASE_POSITION_SOL=0.5

# ── Signal Quality ────────────────────────────────────────────────────────────
# Signals with score below this threshold are logged to DB but NOT alerted.
# (Telegram alert is suppressed, trade queue is not touched)
# Used by: apps/signal-engine
MIN_SIGNAL_SCORE=70

# ── Service Startup Flags ─────────────────────────────────────────────────────
# Set to 'true' on the scorer and/or discovery service to run the batch
# immediately on startup instead of waiting for the 02:00/02:30 UTC cron.
# Useful for: first-run seeding, manual batch triggers.
# Used by: apps/scorer, apps/discovery
RUN_ON_STARTUP=false

# ── Wallet Seeding ────────────────────────────────────────────────────────────
# Optional: comma-separated Solana wallet addresses to ingest on indexer start.
# Alternatively use the API: POST /v1/discovery/from-token or POST /v1/wallets
# Used by: apps/indexer/src/index.ts
WALLET_ADDRESSES=
