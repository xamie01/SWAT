# ── Infrastructure ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://swat:swat@localhost:5432/swat
REDIS_URL=redis://localhost:6379
PORT=3001
WEBHOOK_PORT=3002
NODE_ENV=development

# ── Security ────────────────────────────────────────────────────────────────────
API_KEY=swat-dev-key                # X-Api-Key header required on all API routes
JWT_SECRET=change-me                # Future JWT use

# ── Helius (Solana RPC + Webhooks) ──────────────────────────────────────────────
HELIUS_API_KEY=                     # Get from helius.dev — required for backfill + safety checks
HELIUS_WEBHOOK_SECRET=              # Set this in your Helius webhook config for signature verification

# ── Telegram Alerts ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                 # @BotFather → /newbot
TELEGRAM_CHAT_ID=                   # Your chat or group ID

# ── Execution Bot (Trojan recommended) ──────────────────────────────────────────
TROJAN_WEBHOOK_URL=                 # Trojan webhook URL for auto-buy trigger
TROJAN_API_KEY=                     # Trojan API key (Authorization: Bearer)

# ── Trading Configuration ────────────────────────────────────────────────────────
TRADING_MODE=paper                  # 'paper' or 'live'
AUTO_EXECUTE=false                  # Enable ONLY after 2+ weeks of validated paper signal quality
AUTO_EXECUTE_MIN_SCORE=90           # Minimum signal score to trigger auto-execute (spec default: 90)
BASE_POSITION_SOL=0.5               # Base buy size in SOL before tier/score multipliers applied

# ── Service Flags ───────────────────────────────────────────────────────────────
RUN_ON_STARTUP=false                # Set true on scorer/discovery to run batch immediately on launch
MIN_SIGNAL_SCORE=70                 # Signals below this are logged only, no Telegram alert

# ── Discovery Seeds (optional — use /v1/discovery/from-token endpoint instead) ──
WALLET_ADDRESSES=                   # Comma-separated wallet addresses to seed on indexer startup
