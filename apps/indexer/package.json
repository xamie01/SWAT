{
  "name": "@swat/indexer",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx --env-file=../../.env --import tsx/esm src/webhook.ts & tsx --env-file=../../.env --import tsx/esm src/index.ts",
    "dev:worker": "tsx src/index.ts",
    "dev:webhook": "tsx src/webhook.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node -e \"console.log('No tests in @swat/indexer')\""
  },
  "dependencies": {
    "@swat/db": "workspace:*",
    "@swat/shared": "workspace:*",
    "bullmq": "^5.52.1",
    "fastify": "^5.0.0",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.6.1"
  }
}
